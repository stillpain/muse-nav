---
import { siteConfig } from '@/config';
const { currentPath = '/' } = Astro.props;
const links = [['/', '首页'], ['/#catalog', '分类'], [siteConfig.blogUrl, '博客'], ['/about/', '关于']];
---
<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="/" aria-label={`${siteConfig.name}首页`}><span class="brand-mark">暮</span><span>{siteConfig.name}</span></a>
    <nav id="main-nav" class="main-nav" aria-label="主导航">
      {links.map(([href, label]) => <a href={href} aria-current={currentPath === href ? 'page' : undefined}>{label}</a>)}
    </nav>
    <div class="header-actions">
      <button id="theme-toggle" class="icon-button" type="button" aria-label="切换深浅色模式">◐</button>
      <button id="menu-toggle" class="icon-button menu-button" type="button" aria-label="打开菜单" aria-controls="main-nav" aria-expanded="false">☰</button>
    </div>
  </div>
</header>
<script is:inline>
  const themeButton = document.querySelector('#theme-toggle');
  themeButton?.addEventListener('click', () => {
    const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
    document.documentElement.dataset.theme = next;
    localStorage.setItem('theme', next);
  });
  const menuButton = document.querySelector('#menu-toggle');
  const menu = document.querySelector('#main-nav');
  menuButton?.addEventListener('click', () => {
    const open = menu?.classList.toggle('open') || false;
    menuButton.setAttribute('aria-expanded', String(open));
  });
</script>
