---
import type { Category, Site } from '@/lib/content/types';
const { categories, sites, active } = Astro.props as { categories: Category[]; sites: Site[]; active?: string };
---
<nav class="category-nav" aria-label="网站分类">
  <strong>浏览分类</strong>
  {categories.filter((c) => c.status === 'published').sort((a,b) => a.sortOrder-b.sortOrder).map((category) => {
    const count = sites.filter((site) => site.category === category.slug && site.status === 'published').length;
    return <a class:list={{ active: active === category.slug }} href={active ? `/category/${category.slug}/` : `#${category.slug}`}>
      <span class="category-icon" style={`background:${category.color}`}>{category.icon}</span><span>{category.name}</span><span class="category-count">{count}</span>
    </a>;
  })}
</nav>
