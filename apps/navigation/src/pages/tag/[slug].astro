---
import BaseLayout from '@/layouts/BaseLayout.astro'; import Breadcrumbs from '@/components/Breadcrumbs.astro'; import SiteGrid from '@/components/SiteGrid.astro'; import { getCatalog } from '@/lib/content'; import { publishedSites } from '@/lib/content/selectors'; import { siteConfig } from '@/config';
export async function getStaticPaths() { const catalog = await getCatalog(); return catalog.tags.filter((tag) => tag.status === 'published').map((tag) => ({params:{slug:tag.slug},props:{tag}})); }
const { tag } = Astro.props; const catalog = await getCatalog(); const sites = publishedSites(catalog).filter((site) => site.tags.includes(tag.slug)); const indexed = sites.length >= 8 && tag.description.length >= 40;
---
<BaseLayout title={`${tag.name}网站合集｜${siteConfig.name}`} description={tag.description || `带有${tag.name}标签的精选网站。`} robots={indexed ? 'index,follow' : 'noindex,follow'}><Breadcrumbs items={[{name:'首页',href:'/'},{name:`标签：${tag.name}`}]} /><section class="container page-intro"><p class="eyebrow">Tag</p><h1>#{tag.name}</h1><p class="lead">{tag.description || `整理带有${tag.name}标签的网站。`}</p></section><section class="container" style="padding-bottom:72px;"><SiteGrid sites={sites} /></section></BaseLayout>
