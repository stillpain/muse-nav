---
import BlogLayout from '@/layouts/BlogLayout.astro';
import type { BlogArticle } from '@/data/blog';
import { getBlogArticles } from '@/lib/blog';
import { blogConfig } from '@/config';
export async function getStaticPaths() { const blogArticles = await getBlogArticles(); return blogArticles.map((article) => ({ params: { slug: article.slug }, props: { article, allArticles: blogArticles } })); }
const { article } = Astro.props as { article: BlogArticle };
const { allArticles } = Astro.props as { allArticles: BlogArticle[] };
const related = allArticles.filter((item) => item.slug !== article.slug && (item.category === article.category || item.tags.some((tag) => article.tags.includes(tag)))).slice(0, 2);
const formatDate = new Intl.DateTimeFormat('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' }).format(new Date(article.publishedAt));
const articleJsonLd = {
  '@context': 'https://schema.org', '@type': 'BlogPosting', headline: article.title,
  description: article.excerpt, datePublished: article.publishedAt, dateModified: article.publishedAt,
  mainEntityOfPage: new URL(`/post/${article.slug}/`, blogConfig.siteUrl).toString(),
  author: { '@type': 'Person', name: blogConfig.author },
};
---
<BlogLayout title={`${article.title}｜暮色手记`} description={article.excerpt} type="article" jsonLd={articleJsonLd}>
  <article class="blog-article">
    <header class={`article-header cover-${article.accent}`}><div class="article-header-inner"><a class="article-category" href={`/archive/#${article.category}`}>{article.category}</a><h1>{article.title}</h1><p>{article.excerpt}</p><div class="article-byline"><span class="mini-avatar">暮</span><span><b>暮色手记</b><small><time datetime={article.publishedAt}>{formatDate}</time> · {article.readTime} 分钟阅读</small></span></div></div></header>
    <div class="blog-container article-layout">
      <aside class="article-toc"><strong>本文目录</strong>{article.sections.map((section, index) => <a href={`#section-${index + 1}`}>{section.heading}</a>)}<a class="back-link" href="/">← 返回博客</a></aside>
      <div class="article-prose">
        {article.html ? <div class="wp-article-content" set:html={article.html} /> : article.sections.map((section, index) => <section id={`section-${index + 1}`}><h2>{section.heading}</h2>{section.paragraphs.map((paragraph) => <p>{paragraph}</p>)}{section.points && <ul>{section.points.map((point) => <li>{point}</li>)}</ul>}</section>)}
        <div class="article-tags">{article.tags.map((tag) => <span>#{tag}</span>)}</div>
      </div>
    </div>
  </article>
  {related.length > 0 && <section class="blog-container related-reading"><div class="blog-section-title"><div><p class="eyebrow">KEEP READING</p><h2>继续阅读</h2></div></div><div class="related-grid">{related.map((item) => <a href={`/post/${item.slug}/`}><span>{item.category}</span><h3>{item.title}</h3><p>{item.excerpt}</p></a>)}</div></section>}
</BlogLayout>
