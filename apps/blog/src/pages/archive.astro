---
import BlogLayout from '@/layouts/BlogLayout.astro';
import { getBlogArticles, getBlogCategories } from '@/lib/blog';
const blogArticles = await getBlogArticles();
const blogCategories = getBlogCategories(blogArticles);
const formatDate = (date: string) => new Intl.DateTimeFormat('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' }).format(new Date(date));
---
<BlogLayout title="文章归档｜暮色手记" description="暮色手记的全部文章，按主题浏览独立开发、VPS、建站与数字生活记录。">
  <section class="blog-page-head"><div class="blog-container"><p class="eyebrow">ARCHIVE</p><h1>文章归档</h1><p>不追赶信息流，按自己的节奏记录。这里共有 {blogArticles.length} 篇文章。</p></div></section>
  <div class="blog-container archive-layout">
    <nav class="archive-nav" aria-label="文章分类">{blogCategories.map((category) => <a href={`#${category}`}>{category}</a>)}</nav>
    <div class="archive-groups">
      {blogCategories.map((category) => <section id={category} class="archive-group"><div class="archive-heading"><h2>{category}</h2><span>{blogArticles.filter((item) => item.category === category).length}</span></div>{blogArticles.filter((item) => item.category === category).map((article) => <article><time datetime={article.publishedAt}>{formatDate(article.publishedAt)}</time><div><h3><a href={`/post/${article.slug}/`}>{article.title}</a></h3><p>{article.excerpt}</p></div><span>{article.readTime} min</span></article>)}</section>)}
    </div>
  </div>
</BlogLayout>
