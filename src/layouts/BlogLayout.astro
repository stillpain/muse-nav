---
import BlogHeader from '@/components/BlogHeader.astro';
import SeoHead from '@/components/SeoHead.astro';
import '@/styles/global.scss';
interface Props { title: string; description: string; canonical?: string; robots?: string; }
const props = Astro.props;
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="theme-color" content="#6857d9" />
    <SeoHead {...props} />
    <script is:inline>
      (() => { const saved = localStorage.getItem('theme'); document.documentElement.dataset.theme = saved || (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light'); })();
    </script>
  </head>
  <body class="blog-body">
    <a class="skip-link" href="#main-content">跳到主要内容</a>
    <BlogHeader currentPath={Astro.url.pathname} />
    <main id="main-content" class="blog-main"><slot /></main>
    <footer class="blog-footer"><div class="blog-container"><span>暮色手记 · 写给未来的自己，也分享给恰好路过的人。</span><a href="/">返回网址导航 →</a></div></footer>
  </body>
</html>
