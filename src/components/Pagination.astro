---
const { current, total, base } = Astro.props as { current: number; total: number; base: string };
const href = (page: number) => page === 1 ? base : `${base}page/${page}/`;
---
{total > 1 && <nav class="pagination" aria-label="分页">
  {current > 1 && <a href={href(current - 1)} aria-label="上一页">←</a>}
  {Array.from({ length: total }, (_, i) => i + 1).map((page) => page === current ? <span class="current" aria-current="page">{page}</span> : <a href={href(page)}>{page}</a>)}
  {current < total && <a href={href(current + 1)} aria-label="下一页">→</a>}
</nav>}
