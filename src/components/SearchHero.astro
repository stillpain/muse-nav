<section id="search" class="container hero nav-hero nav-hero-compact" aria-labelledby="search-title">
  <div class="hero-content">
    <p id="search-title" class="search-motto">暮色落下，仍有坐标发亮</p>
    <form id="external-search" class="search-box" action="https://cn.bing.com/search" method="get">
      <label class="sr-only" for="engine">搜索引擎</label>
      <select id="engine" aria-label="搜索引擎"><option value="bing">Bing</option><option value="baidu">百度</option><option value="google">Google</option><option value="local">站内</option></select>
      <label class="sr-only" for="search-query">搜索内容</label>
      <input id="search-query" name="q" type="search" placeholder="搜索网络，或切换到站内搜索" autocomplete="off" required />
      <button type="submit">搜索</button>
    </form>
    <div class="search-shortcut">按 / 聚焦搜索 · 站内搜索只查找已收录网站</div>
  </div>
</section>
<script is:inline>
  const form = document.querySelector('#external-search');
  const engine = document.querySelector('#engine');
  const input = document.querySelector('#search-query');
  const actions = { bing: 'https://cn.bing.com/search', baidu: 'https://www.baidu.com/s', google: 'https://www.google.com/search' };
  engine?.addEventListener('change', () => { input.name = engine.value === 'baidu' ? 'wd' : 'q'; if (engine.value !== 'local') form.action = actions[engine.value]; });
  form?.addEventListener('submit', (event) => { if (engine.value === 'local') { event.preventDefault(); location.href = `/search/?q=${encodeURIComponent(input.value)}`; } });
  document.addEventListener('keydown', (event) => { if (event.key === '/' && !['INPUT','TEXTAREA','SELECT'].includes(document.activeElement?.tagName)) { event.preventDefault(); input?.focus(); } });
</script>
