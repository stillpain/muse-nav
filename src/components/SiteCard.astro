---
import type { Site } from '@/lib/content/types';
import { hasDetail, siteHref } from '@/lib/content/selectors';
const { site } = Astro.props as { site: Site };
const external = !hasDetail(site);
const initial = site.name.slice(0, 2).toUpperCase();
---
<article class="site-card">
  <div class="site-logo" aria-hidden="true">{initial}</div>
  <div class="site-card-content"><h3>{site.name}</h3><p>{site.description}</p></div>
  <span class="site-card-arrow" aria-hidden="true">{external ? '↗' : '→'}</span>
  <a class="card-link" href={siteHref(site)} target={external ? '_blank' : undefined} rel={external ? 'noopener' : undefined} aria-label={`${external ? '访问' : '了解'} ${site.name}`}></a>
</article>
