---
import BaseLayout from '@/layouts/BaseLayout.astro'; import Breadcrumbs from '@/components/Breadcrumbs.astro'; import { siteConfig } from '@/config';
const endpoint = import.meta.env.PUBLIC_SUBMISSION_ENDPOINT || '';
---
<BaseLayout title={`提交网站｜${siteConfig.name}`} description="向暮色导航推荐值得收录的网站。所有提交均需人工审核。" robots="noindex,follow">
  <Breadcrumbs items={[{name:'首页',href:'/'},{name:'提交网站'}]} /><section class="reading page-intro"><p class="eyebrow">Submission</p><h1>推荐一个值得被发现的网站</h1><p class="lead">请说明它解决什么问题，以及你为什么愿意推荐。提交不会自动公开。</p></section><section class="reading content-card rich-copy" style="margin-bottom:72px;"><form id="submission-form" class="form-grid" action={endpoint || undefined} method="post"><div class="field"><label for="name">网站名称</label><input id="name" name="name" required maxlength="80" /></div><div class="field"><label for="url">网站地址</label><input id="url" name="url" type="url" required placeholder="https://" /></div><div class="field"><label for="email">联系邮箱</label><input id="email" name="email" type="email" required /></div><div class="field"><label for="category">建议分类</label><select id="category" name="category"><option>AI 工具</option><option>开发工具</option><option>设计灵感</option><option>学习资源</option><option>效率办公</option><option>VPS 与运维</option></select></div><div class="field full"><label for="reason">推荐理由</label><textarea id="reason" name="reason" rows="6" minlength="30" maxlength="1200" required></textarea></div><div class="field full"><label><input type="checkbox" required /> 我确认所填信息真实，并同意人工审核。</label><button class="button primary" type="submit" disabled={!endpoint}>{endpoint ? '提交审核' : '投稿接口将在第二阶段开放'}</button><p class="muted">本站不会公开你的邮箱，也不会因为提交而保证收录。</p></div></form></section>
</BaseLayout>
