---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import SiteGrid from '@/components/SiteGrid.astro';
import { getCatalog } from '@/lib/content';
import { indexableSites, publishedSites } from '@/lib/content/selectors';
import { siteConfig } from '@/config';
import { breadcrumbJsonLd } from '@/lib/seo/jsonld';

export async function getStaticPaths() {
  const catalog = await getCatalog();
  return indexableSites(catalog).map((site) => ({ params: { slug: site.slug }, props: { site } }));
}
const { site } = Astro.props;
const catalog = await getCatalog();
const category = catalog.categories.find((item) => item.slug === site.category)!;
const alternatives = publishedSites(catalog).filter((item) => site.alternatives.includes(item.slug));
const paragraphs = site.longDescription?.split(/\n\s*\n/).filter(Boolean) || [];
const url = `${siteConfig.siteUrl}/site/${site.slug}/`;
---
<BaseLayout title={`${site.name}是什么？功能、费用与替代方案｜${siteConfig.name}`} description={`${site.description} 本页介绍其主要用途、费用模式、使用注意事项和可选替代产品。`} jsonLd={breadcrumbJsonLd([{name:'首页',url:siteConfig.siteUrl},{name:category.name,url:`${siteConfig.siteUrl}/category/${category.slug}/`},{name:site.name,url}])}>
  <Breadcrumbs items={[{name:'首页',href:'/'},{name:category.name,href:`/category/${category.slug}/`},{name:site.name}]} />
  <article class="reading" style="padding: 34px 0 70px;">
    <header class="content-card detail-hero"><div class="site-logo detail-logo">{site.name.slice(0,2)}</div><div><p class="eyebrow">Curated site</p><h1>{site.name}</h1><p class="muted">{site.description}</p><div class="detail-meta"><span class="pill">{category.name}</span><span class="pill">{site.pricing}</span>{site.tags.map((tag) => <span class="pill">#{catalog.tags.find((item) => item.slug === tag)?.name}</span>)}</div></div><a class="button primary" href={site.url} target="_blank" rel="noopener">访问官网 ↗</a></header>
    <div class="content-card rich-copy" style="margin-top:18px;"><h2>为什么值得了解</h2>{paragraphs.map((paragraph) => <p>{paragraph}</p>)}<h2>编辑说明</h2><p>本页链接指向第三方网站。费用、功能和可用性可能变化，请以官方网站展示为准；我们不参与第三方账户和交易。</p></div>
    {alternatives.length > 0 && <section style="margin-top:36px;"><div class="section-heading"><div><p class="eyebrow">Alternatives</p><h2>可以一起比较</h2></div></div><SiteGrid sites={alternatives} /></section>}
  </article>
</BaseLayout>
