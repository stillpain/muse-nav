---
import BaseLayout from '@/layouts/BaseLayout.astro'; import { siteConfig } from '@/config';
---
<BaseLayout title={`没有找到这个坐标｜${siteConfig.name}`} description="页面不存在或已被移动。" robots="noindex"><section class="reading page-intro" style="padding-block:100px;"><p class="eyebrow">404</p><h1>这个坐标已经熄灭，或者从未存在。</h1><p class="lead">你可以回到导航首页，或者在站内搜索另一个入口。</p><div style="display:flex;gap:12px;margin-top:26px;"><a class="button primary" href="/">返回首页</a><a class="button" href="/search/">站内搜索</a></div></section></BaseLayout>
