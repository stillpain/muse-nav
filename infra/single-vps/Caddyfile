{$SITE_DOMAIN:musedaohang.com} {
    encode zstd gzip
    reverse_proxy muse:3000

    @studio path /studio /studio/*
    header @studio X-Robots-Tag "noindex, nofollow"

    header {
        X-Content-Type-Options nosniff
        Referrer-Policy strict-origin-when-cross-origin
        X-Frame-Options DENY
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
        -Server
    }
}

{$WWW_DOMAIN:www.musedaohang.com} {
    redir https://{$SITE_DOMAIN:musedaohang.com}{uri} permanent
}
